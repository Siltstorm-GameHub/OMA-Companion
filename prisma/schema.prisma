generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
url      = env("DATABASE_URL")
directUrl = env("DIRECT_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?

  discordId     String?   @unique
  username      String?
  role          String    @default("user") // user | moderator | admin
  points        Int       @default(0)   // Münzen (Shop-Währung)
  rankPoints    Int       @default(0)   // Prestige-Punkte (Events, Turniere, LuL)
  createdAt     DateTime  @default(now())

  twitchLogin        String?   @unique
  birthday           DateTime? // Nur Datum relevant (month/day)
  birthdayBoostUntil DateTime? // 2x Punkte bis zu diesem Zeitpunkt
  bio                String?   // Kurzer Gruß / Beschreibung (max. 200 Zeichen)
  xpBoostUntil       DateTime?
  streakShield       Boolean   @default(false)

  // Discord-Aktivität: kumulativ über alle Zeiten
  voiceMinutesTotal Int @default(0)
  messagesTotal     Int @default(0)

  // Collectibles Showcase: JSON-Array mit bis zu 5 CollectibleItem-IDs
  showcaseJson        String?
  // Badge Showcase: JSON-Array mit bis zu 3 Badge-Keys (system oder custom-id)
  showcaseBadgesJson  String?
  // Notification-Präferenzen: JSON-Objekt { badge: bool, quest: bool, event: bool, points: bool, clip: bool, admin: bool }
  notificationPrefs   String  @default("{}")

  accounts      Account[]
  sessions      Session[]
  eventRegistrations        EventRegistration[]
  pointTransactions         PointTransaction[]
  tournamentParticipants    TournamentParticipant[]
  teamMemberships           TeamMember[]
  matchEntries              MatchEntry[]
  questProgress             UserQuestProgress[]
  lulEntries                LulEntry[]
  lulLegacyEntries          LulLegacyEntry[]
  shopPurchases             ShopPurchase[]
  lulSuggestions            LulSuggestion[]
  dailySpins                DailySpin[]
  donations                 Donation[]
  collectibles              UserCollectible[]
  lobbyMessages             LobbyMessage[]
  pushSubscriptions         PushSubscription[]
  clipSubmissions           EventClipSubmission[]
  clipNominations           ClipNomination[]
  contestVotes              ClipContestVote[]
  eventPollVotes            EventPollVote[]
  systemBadges              UserSystemBadge[]
  customBadgeAwards         UserCustomBadge[]
  dailyMessages             DailyMessage[]
  wanderpocalHoldings       WanderpocalHolder[]
  wanderpocalStats          WanderpocalStat[]
  communityStreams           EventCommunityStreamer[]
  linkedPartner             Partner?
  notifications             InAppNotification[]
  lulPollVotesGiven         LulPollVote[]       @relation("LulPollVoter")
  lulPollVotesReceived      LulPollVote[]       @relation("LulPollTarget")
  serverApplications        ServerApplication[]
}

// ── Collectibles ─────────────────────────────────────────────────────────────

model CollectibleCollection {
  id             String   @id @default(cuid())
  name           String
  description    String?
  game           String?              // z.B. "Rocket League"
  coverImageUrl  String?              // URL zum Cover-Bild (Supabase Storage)
  active         Boolean  @default(true)  // im Shop anzeigen?
  sortOrder      Int      @default(0)
  createdAt      DateTime @default(now())

  items       CollectibleItem[]
}

model CollectibleItem {
  id           String   @id @default(cuid())
  collectionId String
  name         String
  description  String?
  imageUrl     String?              // URL zum Figuren-Bild (Supabase Storage)
  rarity       String   @default("common") // common | rare | epic | legendary
  price        Int
  salePrice    Int?                 // Rabattpreis (null = kein Rabatt)
  saleUntil    DateTime?            // Rabatt läuft bis (null = unbegrenzt)
  active       Boolean  @default(true)     // im Shop anzeigen?
  stock        Int?     // null = unbegrenzt
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())

  collection   CollectibleCollection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  owners       UserCollectible[]
}

model UserCollectible {
  id                String   @id @default(cuid())
  userId            String
  collectibleItemId String
  createdAt         DateTime @default(now())

  user              User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  collectibleItem   CollectibleItem @relation(fields: [collectibleItemId], references: [id], onDelete: Cascade)

  @@unique([userId, collectibleItemId])
}

// ── Shop (nur noch lul_suggest) ──────────────────────────────────────────────

model ShopItem {
  id          String   @id @default(cuid())
  name        String
  description String
  icon        String
  price       Int
  // title | badge | streak_shield | xp_boost | profile_theme | event_slot
  type        String
  value       String   // Titel-Text | Badge-ID | Theme-Name | "1" für Einmalitems
  // cosmetic | boost | privilege
  category    String
  // common | rare | epic | legendary
  rarity      String   @default("common")
  stock         Int?      // null = unbegrenzt
  active        Boolean   @default(true)
  sortOrder     Int       @default(0)
  availableFrom DateTime? // null = sofort verfügbar
  availableTo   DateTime? // null = kein Ablaufdatum
  createdAt     DateTime  @default(now())

  purchases     ShopPurchase[]
}

model ShopPurchase {
  id        String    @id @default(cuid())
  userId    String
  itemId    String
  price     Int
  createdAt DateTime  @default(now())
  expiresAt DateTime?
  consumed  Boolean   @default(false) // für Einmalitems (Streak-Schutz, Event-Slot)

  user        User           @relation(fields: [userId], references: [id])
  item        ShopItem       @relation(fields: [itemId], references: [id])
  lulSuggestion LulSuggestion?
}

model LulSuggestion {
  id         String      @id @default(cuid())
  purchaseId String      @unique
  userId     String
  game       String
  note       String?
  status     String      @default("pending") // pending | accepted | rejected
  createdAt  DateTime    @default(now())

  purchase   ShopPurchase @relation(fields: [purchaseId], references: [id])
  user       User         @relation(fields: [userId], references: [id])
}

// ── Täglicher Gratis-Spin ──────────────────────────────────────────────────
model DailySpin {
  id         String   @id @default(cuid())
  userId     String
  date       String   // "YYYY-MM-DD" — ein Spin pro Tag
  prizeType  String   // "points" | "nothing"
  prizeValue String   // Punkte als String oder "0"
  prizeLabel String   // Anzeigetext
  createdAt  DateTime @default(now())

  user       User     @relation(fields: [userId], references: [id])
  @@unique([userId, date])
}


// ── Auktionen ──────────────────────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime
  @@unique([identifier, token])
}

model EventSeries {
  id          String   @id @default(cuid())
  name        String
  description String?
  fixedGame        String?  // Wenn gesetzt: alle Events der Reihe nutzen dieses Spiel
  fixedFormat      String?  // Wenn gesetzt: alle Turniere der Reihe nutzen dieses Format
  discordChannelId String?  // Kanal-ID für Bot-Nachrichten aller Events dieser Reihe
  category         EventCategory  @default(casual)
  genre            EventGenre?
  platform         String?  // Komma-getrennte Plattformen, z.B. "PC, Xbox"
  recurrenceType       String?  // "weekly" | "biweekly" | "monthly"
  recurrenceMonthlyMode String? // "dayOfMonth" | "weekdayOfMonth" (nur bei monthly)
  // JSON: { participationPoints: 5, stats: [{ field: "Kills", pointsPer: 2, isWinnerStat?, isMatchWinStat? }], mvpStatField?: "MVP", defaultWinnerStatField?: "Kills", defaultWinnerTargetField?: "Siege", winnerStatKeys?: string[], matchWinStatKeys?: string[] }
  seriesStatConfig String?
  // JSON: [{ userId, points, participations, stats: { Kills: 45 } }]
  legacyStandings String?
  // JSON: { lastUpdated, processedEventIds: string[], raw: { userId: { participations, Kills, MVP, Siege, ... } } }
  seriesStandingsJson String?
  // JSON: { participationCoins: 10, placements: [{ place: 1, coins: 500, rankPoints: 3 }, ...] }
  placementRewardsJson String?
  // JSON: { enabled: bool, question: string, coins: 250, rankPoints: 3 }
  pollConfigJson       String?
  // JSON: [{ label, question, coins, rankPoints, type: "player"|"spectator" }]
  pollsConfigJson      String?
  // Saison-Archiv
  groupId              String?   // verbindet alle Saisons derselben Reihe
  status               String    @default("active") // "active" | "archived"
  hidden               Boolean   @default(false)    // true = nur im Admin sichtbar
  seasonNumber         Int?      // 1, 2, 3 …
  archivedAt           DateTime?
  // JSON: analog zu event.completionData (overallWinnerIds, finalRanking, poll*, lockedAt)
  seriesCompletionData String?
  createdAt   DateTime @default(now())
  events      Event[]
  lulSeason   LulSeason?
}

model Event {
  id             String   @id @default(cuid())
  title          String
  description    String?
  game           String?
  genre          EventGenre?
  category       EventCategory  @default(casual)
  startAt        DateTime
  maxPlayers     Int?
  pointReward    Int      @default(50)
  spectatorMode  Boolean  @default(false)
  spectatorRewardJson String? // JSON: { coins: number, rankPoints: number }
  type           String   @default("community")
  status         String   @default("open")
  hidden         Boolean  @default(false)    // true = nur im Admin sichtbar
  discordEventId   String?  @unique
  discordMessageId String?  // Message-ID der Bot-Ankündigung (zum nachträglichen Löschen)
  discordChannelId String?   // Kanal-ID für Bot-Nachrichten (überschreibt DISCORD_EVENTS_CHANNEL_ID)
  seriesId         String?
  reminderSentAt   DateTime? // Gesetzt wenn 24h-Erinnerung verschickt (verhindert Doppel-Sendung)
  // JSON: { mvpUserId?, winnerStatField?, seriesWinnerTargetField?, lockedAt }
  completionData   String?
  createdAt      DateTime @default(now())

  // Ehem. Tournament-Felder (zusammengeführt)
  format           String?   // single_elimination | double_elimination | round_robin | ffa | coop_stats | avg_stats
  tournamentStatus String?   // pending | active | complete | finalized
  pointsConfig     String?   // JSON: {"1": 100, "2": 50, "3": 25} — legacy, nur Münzen
  statFields       String?   // JSON: ["Kills","Assists"]
  finalRankingJson String?   // JSON: ["userId1","userId2"]
  finalRankingNote String?
  // JSON: { participationCoins: 10, placements: [{ place: 1, coins: 500, rankPoints: 3 }, ...] }
  placementRewardsJson String?
  // JSON: { enabled: bool, question: string, coins: 250, rankPoints: 3 }
  pollConfigJson       String?
  // JSON: [{ label, question, coins, rankPoints, type: "player"|"spectator" }]
  pollsConfigJson      String?
  // JSON: { winnerMode: "manual"|"bracket"|"stat", winnerStatField?: string }
  seriesEventConfigJson String?
  summary              String?
  twitchClipUrl        String?

  series        EventSeries?        @relation(fields: [seriesId], references: [id])
  lulSpieltag   LulSpieltag?
  registrations EventRegistration[]
  participants  TournamentParticipant[]
  matches       Match[]
  teams         Team[]
  streamingPartners    EventPartner[]
  communityStreamers   EventCommunityStreamer[]
  clipSubmissions      EventClipSubmission[]
  polls                EventPoll[]
}

// ── Event-Umfragen ────────────────────────────────────────────────────────────

model EventPoll {
  id                        String   @id @default(cuid())
  eventId                   String
  event                     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  label                     String   // z.B. "MVP"
  question                  String   // z.B. "Wer war der MVP?"
  // "all" | "participants" | "players" | "spectators"
  voterEligibility          String   @default("all")
  // "players" | "spectators" | "custom"
  answerType                String   @default("players")
  // JSON: [{key: string, label: string}] — nur bei answerType="custom"
  customAnswers             String?
  startAt                   DateTime
  endAt                     DateTime
  participationCoins        Int      @default(0)
  participationSeriesPoints Int      @default(0)
  winnerCoins               Int      @default(0)
  winnerRankPoints          Int      @default(0)
  // JSON: ["userId1", "userId2"] — nach Auswertung gesetzt
  winnerIds                 String?
  // true wenn Belohnungen bereits vergeben wurden
  rewardsPaid               Boolean  @default(false)
  createdAt                 DateTime @default(now())
  votes                     EventPollVote[]
}

model EventPollVote {
  id        String    @id @default(cuid())
  pollId    String
  poll      EventPoll @relation(fields: [pollId], references: [id], onDelete: Cascade)
  voterId   String
  voter     User      @relation(fields: [voterId], references: [id], onDelete: Cascade)
  // userId (für players/spectators) oder custom answer key
  targetId  String
  isManual  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([pollId, voterId])
}

// ── Clip-Einreichungen ────────────────────────────────────────────────────────

model EventClipSubmission {
  id        String   @id @default(cuid())
  eventId   String
  userId    String
  clipUrl   String
  createdAt DateTime @default(now())
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([eventId, userId])
}

// ── Partner ──────────────────────────────────────────────────────────────────

model Partner {
  id          String   @id @default(cuid())
  name        String
  twitchLogin String   @unique
  logoUrl     String
  isActive    Boolean  @default(true)
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  // Optional link to a community member account
  userId      String?  @unique
  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  events      EventPartner[]
}

model EventPartner {
  id        String  @id @default(cuid())
  eventId   String
  partnerId String
  event     Event   @relation(fields: [eventId], references: [id], onDelete: Cascade)
  partner   Partner @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  @@unique([eventId, partnerId])
}

// ── Clip des Monats ───────────────────────────────────────────────────────────

model MonthlyClipContest {
  id          String           @id @default(cuid())
  month       Int              // Anzeige-Monat (Monat von periodStart)
  year        Int
  periodStart DateTime         @default(now()) // Beginn des bewerteten Clip-Zeitraums
  periodEnd   DateTime         @default(now()) // Ende des bewerteten Clip-Zeitraums
  votingEndsAt DateTime        @default(now()) // Wann die Abstimmung automatisch endet/ausgewertet wird
  channelsJson String?         // JSON: string[] — abgefragte Twitch-Kanäle
  status      String           @default("voting") // voting | finished
  participationCoins Int       @default(10)  // Münzen für jeden, der abstimmt
  rewardCoins Int              @default(500) // Münzen für den Gewinner-Clip
  winnerNominationIds String[] @default([]) // Bei Gleichstand: mehrere Gewinner möglich
  createdAt   DateTime         @default(now())
  nominations ClipNomination[]
  votes       ClipContestVote[]
  @@index([month, year])
}

model ClipNomination {
  id                 String             @id @default(cuid())
  contestId          String
  clipUrl            String
  thumbnailUrl       String?
  clipTitle          String?
  submittedByUserId  String?            // Community-Clip: User der eingereicht hat
  twitchCreatorLogin String?            // Partner-Clip: Twitch-Login des Clip-Erstellers
  partnerTwitchLogin String?            // Partner-Clip: Twitch-Login des Kanals
  contest            MonthlyClipContest @relation(fields: [contestId], references: [id], onDelete: Cascade)
  submittedBy        User?              @relation(fields: [submittedByUserId], references: [id], onDelete: SetNull)
  votes              ClipContestVote[]
  createdAt          DateTime           @default(now())
}

model ClipContestVote {
  id           String             @id @default(cuid())
  contestId    String
  nominationId String
  userId       String
  contest      MonthlyClipContest @relation(fields: [contestId], references: [id], onDelete: Cascade)
  nomination   ClipNomination     @relation(fields: [nominationId], references: [id], onDelete: Cascade)
  user         User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt    DateTime           @default(now())
  @@unique([contestId, userId])
}

// Community members who self-register as streamer for an event
model EventCommunityStreamer {
  id        String   @id @default(cuid())
  eventId   String
  userId    String
  createdAt DateTime @default(now())
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([eventId, userId])
}

model EventRegistration {
  id        String   @id @default(cuid())
  userId    String
  eventId   String
  joinedAt  DateTime @default(now())
  attended  Boolean  @default(false)
  role      String   @default("player") // "player" | "spectator"
  user      User     @relation(fields: [userId], references: [id])
  event     Event    @relation(fields: [eventId], references: [id])
  @@unique([userId, eventId])
}

model TournamentParticipant {
  id       String  @id @default(cuid())
  eventId  String
  userId   String
  seed     Int?
  eliminated Boolean @default(false)
  finalRank  Int?
  event    Event   @relation(fields: [eventId], references: [id])
  user     User    @relation(fields: [userId], references: [id])
  @@unique([eventId, userId])
}

// Nur für team_vs_team-Formate
model Team {
  id       String     @id @default(cuid())
  eventId  String
  name     String
  color    String?
  event    Event      @relation(fields: [eventId], references: [id])
  members  TeamMember[]
  matchEntries MatchEntry[]
}

model TeamMember {
  id     String @id @default(cuid())
  teamId String
  userId String
  team   Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id])
  @@unique([teamId, userId])
}

model Match {
  id        String     @id @default(cuid())
  eventId   String
  round     Int
  position  Int
  title     String?
  scheduledAt DateTime?
  notes     String?
  // 1v1 / single_elimination: player1Id/player2Id/score1/score2/winnerId
  player1Id String?
  player2Id String?
  winnerId  String?
  score1    Int?
  score2    Int?
  playedAt  DateTime?
  event     Event      @relation(fields: [eventId], references: [id])
  // ffa / coop_stats / team_vs_team: eine Zeile pro Teilnehmer
  entries   MatchEntry[]
}

// Flexible Teilnehmer-Zeile für FFA, Coop und Team-Matches
model MatchEntry {
  id        String  @id @default(cuid())
  matchId   String
  // Entweder userId (Einzelspieler) oder teamId (Team)
  userId    String?
  teamId    String?
  placement Int?    // Platzierung (1 = Erster)
  score     Int?    // Numerischer Score/Punkte im Match
  // JSON: {"Kills": 12, "Assists": 3} — passend zu Tournament.statFields
  statsJson String?
  match     Match   @relation(fields: [matchId], references: [id], onDelete: Cascade)
  user      User?   @relation(fields: [userId], references: [id])
  team      Team?   @relation(fields: [teamId], references: [id])
}

model Quest {
  id          String   @id @default(cuid())
  title       String
  description String
  // VOICE_MINUTES | MESSAGES | EVENT_ATTEND | TOURNAMENT
  type        String
  target      Int
  reward      Int
  month       Int
  year        Int
  createdAt   DateTime @default(now())

  progress    UserQuestProgress[]
}

model UserQuestProgress {
  id          String    @id @default(cuid())
  userId      String
  questId     String
  current     Int       @default(0)
  completed   Boolean   @default(false)
  completedAt DateTime?
  rewarded    Boolean   @default(false)

  user        User      @relation(fields: [userId], references: [id])
  quest       Quest     @relation(fields: [questId], references: [id], onDelete: Cascade)

  @@unique([userId, questId])
}

// ── Spendenpool ─────────────────────────────────────────────────────────────

model PoolExpense {
  id          String   @id @default(cuid())
  title       String   // z.B. "Minecraft Server Oktober"
  description String?  // optionale Details
  amount      Float    // in Euro
  date        DateTime // Datum der Ausgabe
  createdAt   DateTime @default(now())
}

model PoolIdea {
  id            String   @id @default(cuid())
  title         String   // z.B. "Neuer Gameserver"
  description   String?  // optionale Details
  estimatedCost Float?   // Schätzpreis in Euro
  createdAt     DateTime @default(now())
}

model Donation {
  id        String   @id @default(cuid())
  userId    String
  amount    Float    // in Euro, nur für Admin sichtbar
  month     Int      // 1–12
  year      Int
  note      String?  // optionale Admin-Notiz
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id])
  // Kein Unique-Constraint → mehrere Einträge pro User pro Monat möglich
}

model PointTransaction {
  id        String   @id @default(cuid())
  userId    String
  amount    Int
  reason    String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}

// ── Bot-Konfiguration ────────────────────────────────────────────────────────

model BotConfig {
  key       String   @id  // z.B. "event_new_enabled", "event_new_text"
  value     String        // "true" / "false" / Freitext
  updatedAt DateTime @updatedAt
}

// ── Vereinheitlichte Notification-Registry ──────────────────────────────────

model NotificationRule {
  key         String @id // z.B. "event_new", "quest_completed"
  label       String
  description String
  category    String // events | tournaments | quests | badges | clips | rank | system

  pushEnabled        Boolean @default(true)
  inAppEnabled       Boolean @default(true)
  discordDmEnabled   Boolean @default(false)
  discordChanEnabled Boolean @default(true)
  discordChannelId   String? // leer = DISCORD_NEWS_CHANNEL_ID

  titleTemplate String
  bodyTemplate  String
  urlTemplate   String?

  reminderHoursBefore Int? // nur für "event_reminder" relevant

  // Event-Bezug: wenn true, verlinkt die Benachrichtigung automatisch zum konkreten
  // Event statt zum Ziel-Link oben, und eventAudience steuert den Empfängerkreis.
  isEventNotification Boolean @default(false)
  eventAudience       String  @default("all") // "all" | "participants" (Mitspieler + Zuschauer + Streamer des Events)

  // Soft-Delete: Zeile bleibt bestehen, damit der Seed-Lauf sie beim nächsten
  // Deploy nicht automatisch wieder anlegt (upsert fasst existierende Zeilen nicht an).
  deleted Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ── Level-Up-League ─────────────────────────────────────────────────────────

model LulSeason {
  id             String   @id @default(cuid())
  number         Int      // Saison-Nummer (1, 2, ...)
  name           String?  // optionaler Anzeigename
  period         String?  // "Mai 2026 - Dezember 2026"
  totalSpieltage Int      @default(8)
  // upcoming | active | finished | archived
  status         String   @default("upcoming")
  // true = Vergangene Saison, Daten nur als Endergebnis importiert
  isLegacy       Boolean  @default(false)
  // JSON: { game, spectator, gameWinner, vote, dominion, dominionTriggers: string[], polls: [{statKey, label, points}] }
  pointsConfig   String?
  // Wenn gesetzt: diese Saison wird als normale EventSeries behandelt (neues System)
  seriesId       String?  @unique
  createdAt      DateTime @default(now())

  spieltage     LulSpieltag[]
  legacyEntries LulLegacyEntry[]
  series        EventSeries? @relation(fields: [seriesId], references: [id])
}

// Aggregiertes Saison-Endergebnis für vergangene Saisons ohne Spieltag-Details
model LulLegacyEntry {
  id           String    @id @default(cuid())
  seasonId     String
  userId       String
  totalPts     Int       @default(0)
  asPlayer     Int       @default(0)  // Einsätze als Mitspieler
  asSpectator  Int       @default(0)  // Einsätze als Zuschauer
  wins         Int       @default(0)  // Game Winner
  champs       Int       @default(0)  // Community-Champ (Legacy)
  trost        Int       @default(0)  // Trostpreis (Legacy)
  dominion     Int       @default(0)  // Dominion Bonus
  votes        Int       @default(0)  // Votes
  // JSON: { "communityChamp": 3, "trostpreis": 1, "mvp": 2 } – für neue flexible Saisons
  pollStatsJson String?
  season       LulSeason @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  user         User      @relation(fields: [userId], references: [id])
  @@unique([seasonId, userId])
}

model LulSpieltag {
  id           String    @id @default(cuid())
  seasonId     String
  number       Int       // 1-8
  isSpecial        Boolean   @default(false)
  title            String?   // Titel für Special Events
  description      String?   // Beschreibung für Special Events
  maxPlayers       Int?      // Maximale Spieleranzahl
  tournamentFormat String?   // single_elimination | double_elimination | round_robin | liga | ffa | coop_stats
  statFields       String?   // JSON: ["Kills","Assists"] — für ffa/coop_stats/avg_stats
  matchesJson      String?   // JSON: [{id,p1,p2,s1,s2,winner}] — für 1v1-Formate
  game             String?   // "Brawlhalla" (optional bei Special Events)
  gameType     String?   // "Beat-em Up"
  platform     String?   // "PC/Konsole"
  scheduledAt    DateTime?
  discordEventId String?   @unique
  // upcoming | active | umfrage | finished
  status         String    @default("upcoming")
  // JSON: {"1": 10, "2": 5, "3": 3} – Punkte pro Spielplatzierung
  pointsConfig String?
  // Wenn gesetzt: dieser Spieltag ist auch als reguläres Event sichtbar
  eventId      String?   @unique
  season       LulSeason @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  event        Event?    @relation(fields: [eventId], references: [id])
  entries      LulEntry[]
  polls        LulPoll[]
}

model LulEntry {
  id             String      @id @default(cuid())
  spieltagId     String
  userId         String
  // player | spectator
  role           String      @default("player")
  // JSON number[]: Punkte pro Runde (max 10), nur für Mitspieler
  roundScores    String?
  totalGameScore Int         @default(0)
  placement      Int?        // Spieltagsplatzierung (1 = Sieger)
  gameWinner     Boolean     @default(false) // Mitspieler-Sieg
  communityChamp Boolean     @default(false) // Zuschauer-Umfragesieg (Legacy + statKey="communityChamp")
  trostpreis     Boolean     @default(false) // Trostpreis-Umfrage (Legacy + statKey="trostpreis")
  voted          Boolean     @default(false) // hat an Umfrage teilgenommen
  dominionBonus  Boolean     @default(false) // 3 Siege in Folge
  lulPoints      Int         @default(0)     // LUL-Punkte gesamt für diesen Spieltag
  statsJson      String?                     // JSON: {"Kills":12} — für ffa/coop_stats/avg_stats
  // JSON: ["communityChamp","trostpreis"] — gewonnene Umfragen via statKey (neue flexible Saisons)
  pollWinsJson   String?
  spieltag       LulSpieltag @relation(fields: [spieltagId], references: [id], onDelete: Cascade)
  user           User        @relation(fields: [userId], references: [id])
  @@unique([spieltagId, userId])
}

// ── LUL In-App Voting ────────────────────────────────────────────────────────

// Eine konfigurierbare Umfrage pro Spieltag (mehrere möglich)
model LulPoll {
  id          String      @id @default(cuid())
  spieltagId  String
  // statKey aus pointsConfig.polls (z.B. "communityChamp", "trostpreis", "mvp")
  statKey     String
  label       String      // Anzeigename, z.B. "Community Champ"
  question    String      // z.B. "Wer war der beste Zuschauer?"
  // "player" | "spectator" — wer zur Auswahl steht
  type        String
  endsAt      DateTime
  // JSON: string[] — UserIds die ausgeschlossen sind
  excludedUserIds String?
  // open | closed
  status      String      @default("open")
  // JSON: string[] — UserIds die gewonnen haben (gesetzt beim Schließen)
  winnerIds   String?
  createdAt   DateTime    @default(now())

  spieltag    LulSpieltag @relation(fields: [spieltagId], references: [id], onDelete: Cascade)
  votes       LulPollVote[]
}

// Eine Stimme pro User pro Umfrage — UPDATE erlaubt, DELETE nicht
model LulPollVote {
  id        String   @id @default(cuid())
  pollId    String
  voterId   String
  targetId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  poll      LulPoll  @relation(fields: [pollId], references: [id], onDelete: Cascade)
  voter     User     @relation("LulPollVoter", fields: [voterId], references: [id])
  target    User     @relation("LulPollTarget", fields: [targetId], references: [id])

  @@unique([pollId, voterId])
}

// ── Geplante Discord-Umfragen ─────────────────────────────────────────────
model PollJob {
  id          String    @id @default(cuid())
  // "event_winner" | "lul_trostpreis" | "lul_community"
  type        String
  // eventId oder spieltagId (je nach type)
  refId       String
  // Discord Channel-ID, in dem die Umfrage gepostet wird
  channelId   String
  // Wann soll die Umfrage gesendet werden?
  scheduledAt DateTime
  // Laufzeit in Stunden (Standard: 168 = 1 Woche)
  duration    Int       @default(168)
  // Frage-Text (editierbar im Admin, wird 1:1 an Discord gesendet)
  question         String?
  excludedUserIds  String[]  @default([])
  customAnswers    String[]  @default([])
  allowMultiselect Boolean   @default(false)
  // "pending" | "sent" | "cancelled" | "failed"
  status      String    @default("pending")
  // Discord Message-ID nach dem Senden (zum Nachverfolgen)
  messageId   String?
  // Fehlermeldung falls status = "failed"
  errorMsg    String?
  createdAt   DateTime  @default(now())
  sentAt      DateTime?
}

// ── Lobby-Chat ───────────────────────────────────────────────────────────────

model LobbyMessage {
  id        String   @id @default(cuid())
  content   String   @db.VarChar(500)
  userId    String   @map("userid")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now()) @map("createdat")

  @@index([createdAt])
  @@map("lobbymessage")
}

// ── Abzeichen ────────────────────────────────────────────────────────────────

// Automatisch vergebene System-Abzeichen (definiert in badges.ts)
model UserSystemBadge {
  userId   String
  badgeKey String
  earnedAt DateTime @default(now())
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@id([userId, badgeKey])
}

// Admin-erstellte Custom-Abzeichen
model CustomBadge {
  id        String            @id @default(cuid())
  icon      String            // Emoji
  name      String
  desc      String
  category  String            // "community" | "aktivitaet" | "events" | "turniere" | "punkte" | "special"
  coins     Int               @default(0)  // optionale Münzen-Belohnung
  createdAt DateTime          @default(now())
  createdBy String            // Admin-User-ID
  awards    UserCustomBadge[]
}

// Manuell vergebene Custom-Abzeichen
model UserCustomBadge {
  userId        String
  customBadgeId String
  earnedAt      DateTime    @default(now())
  awardedBy     String      // Admin-User-ID
  note          String?     // optionale Notiz vom Admin
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  badge         CustomBadge @relation(fields: [customBadgeId], references: [id], onDelete: Cascade)
  @@id([userId, customBadgeId])
}

// ── Wanderpokal ──────────────────────────────────────────────────────────────

model WanderpocalHolder {
  id         String   @id @default(cuid())
  userId     String
  scopeType  String   // "category" | "genre"
  scopeValue String   // z.B. "competitive", "arcade"
  winCount   Int
  heldSince  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([scopeType, scopeValue])
  @@index([userId])
}

model WanderpocalStat {
  id         String @id @default(cuid())
  userId     String
  scopeType  String
  scopeValue String
  winCount   Int
  user       User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, scopeType, scopeValue])
  @@index([scopeType, scopeValue, winCount])
}

// ── Event-Enums ───────────────────────────────────────────────────────────────

enum EventCategory {
  competitive
  fun
  casual
  training
  community_event
  special
}

enum EventGenre {
  arcade
  beat_em_up
  sport
  racing
  shooter
  community
}

// ── Tägliche Mitteilungen ────────────────────────────────────────────────────

model DailyMessage {
  id        String   @id @default(cuid())
  title     String
  content   String
  startDate DateTime
  endDate   DateTime
  isActive  Boolean  @default(true)
  createdBy String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  creator   User     @relation(fields: [createdBy], references: [id])
}

// ── In-App-Benachrichtigungen ────────────────────────────────────────────────

model InAppNotification {
  id        String   @id @default(cuid())
  userId    String   @map("userid")
  type      String   // "badge" | "quest" | "event_result" | "event_start" | "points" | "coins" | "clip" | "admin" | "server"
  title     String
  body      String
  url       String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now()) @map("createdat")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
  @@map("inappnotification")
}

// ── Ranglisten-Snapshot ───────────────────────────────────────────────────────

model LeaderboardRankSnapshot {
  id        String   @id @default(cuid())
  takenAt   DateTime @default(now())
  // JSON: { [userId]: rank } – Rang jedes Users zum Snapshot-Zeitpunkt
  dataJson  String
}

// ── Push-Benachrichtigungen ──────────────────────────────────────────────────

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String   @map("userid")
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now()) @map("createdat")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("pushsubscription")
}

// ── Community-Gameserver ─────────────────────────────────────────────────────

model GameServer {
  id          String   @id @default(cuid())
  name        String
  game        String                 // Freitext, z.B. "Minecraft", "ARK: Survival Ascended"
  description String?
  host        String                 // IP/Domain – nur für genehmigte User sichtbar
  port        String?
  password    String?                // Server-Passwort – nur für genehmigte User sichtbar
  connectInfo String?                // Freitext, z.B. Mod-Liste, Connect-String
  maxSlots    Int
  isActive    Boolean  @default(true)
  createdBy   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  applications ServerApplication[]

  @@map("gameserver")
}

model ServerApplication {
  id              String     @id @default(cuid())
  serverId        String
  userId          String
  status          String     @default("pending") // pending | approved | denied | revoked
  message         String?
  adminNote       String?
  appliedAt       DateTime   @default(now())
  decidedAt       DateTime?
  decidedBy       String?
  lastConnectedAt DateTime?  // Zeitpunkt des letzten Klicks auf "Jetzt verbinden" (Info für Admins)

  server GameServer @relation(fields: [serverId], references: [id], onDelete: Cascade)
  user   User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([serverId, userId])
  @@index([serverId, status])
  @@map("serverapplication")
}
