generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
url      = env("DATABASE_URL")
directUrl = env("DIRECT_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?

  discordId     String?   @unique
  username      String?
  role          String    @default("user") // user | moderator | admin
  points        Int       @default(0)   // Münzen (Shop-Währung)
  rankPoints    Int       @default(0)   // Prestige-Punkte (Events, Turniere, LuL)
  goalItemId    String?   // Shop-Item das als Sparziel gesetzt wurde
  createdAt     DateTime  @default(now())

  // Shop / Cosmetics
  activeTitle    String?   // z.B. "Veteran", "Champion"
  profileTheme   String    @default("default") // default | cyber | golden | void | emerald | crimson
  nameColor      String?   // hex color, z.B. "#f59e0b"
  statusMessage  String?   // max 60 Zeichen, sichtbar im Profil
  streakShield        Boolean   @default(false)
  xpBoostUntil        DateTime?
  birthday            DateTime? // Nur Datum relevant (month/day)
  birthdayBoostUntil  DateTime? // 2x Punkte bis zu diesem Zeitpunkt

  accounts      Account[]
  sessions      Session[]
  eventRegistrations        EventRegistration[]
  pointTransactions         PointTransaction[]
  tournamentParticipants    TournamentParticipant[]
  teamMemberships           TeamMember[]
  matchEntries              MatchEntry[]
  questProgress             UserQuestProgress[]
  lulEntries                LulEntry[]
  lulLegacyEntries          LulLegacyEntry[]
  shopPurchases             ShopPurchase[]
  lulSuggestions            LulSuggestion[]
  dailySpins                DailySpin[]
  wishlistItems             WishlistItem[]
  auctionBids               AuctionBid[]
  donations                 Donation[]
  currentAuctions           ShopAuction[]  @relation("currentAuctions")
  wonAuctions               ShopAuction[]  @relation("wonAuctions")
}

// ── Shop ────────────────────────────────────────────────────────────────────

model ShopItem {
  id          String   @id @default(cuid())
  name        String
  description String
  icon        String
  price       Int
  // title | badge | streak_shield | xp_boost | profile_theme | event_slot
  type        String
  value       String   // Titel-Text | Badge-ID | Theme-Name | "1" für Einmalitems
  // cosmetic | boost | privilege
  category    String
  // common | rare | epic | legendary
  rarity      String   @default("common")
  stock         Int?      // null = unbegrenzt
  active        Boolean   @default(true)
  sortOrder     Int       @default(0)
  availableFrom DateTime? // null = sofort verfügbar
  availableTo   DateTime? // null = kein Ablaufdatum
  createdAt     DateTime  @default(now())

  purchases     ShopPurchase[]
  auctions      ShopAuction[]
  wishlistItems WishlistItem[]
}

model ShopPurchase {
  id        String    @id @default(cuid())
  userId    String
  itemId    String
  price     Int
  createdAt DateTime  @default(now())
  expiresAt DateTime?
  consumed  Boolean   @default(false) // für Einmalitems (Streak-Schutz, Event-Slot)

  user        User           @relation(fields: [userId], references: [id])
  item        ShopItem       @relation(fields: [itemId], references: [id])
  lulSuggestion LulSuggestion?
}

model LulSuggestion {
  id         String      @id @default(cuid())
  purchaseId String      @unique
  userId     String
  game       String
  note       String?
  status     String      @default("pending") // pending | accepted | rejected
  createdAt  DateTime    @default(now())

  purchase   ShopPurchase @relation(fields: [purchaseId], references: [id])
  user       User         @relation(fields: [userId], references: [id])
}

// ── Täglicher Gratis-Spin ──────────────────────────────────────────────────
model DailySpin {
  id         String   @id @default(cuid())
  userId     String
  date       String   // "YYYY-MM-DD" — ein Spin pro Tag
  prizeType  String   // "points" | "nothing"
  prizeValue String   // Punkte als String oder "0"
  prizeLabel String   // Anzeigetext
  createdAt  DateTime @default(now())

  user       User     @relation(fields: [userId], references: [id])
  @@unique([userId, date])
}

// ── Wunschliste ────────────────────────────────────────────────────────────
model WishlistItem {
  id        String   @id @default(cuid())
  userId    String
  itemId    String
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id])
  item      ShopItem @relation(fields: [itemId], references: [id])
  @@unique([userId, itemId])
}

// ── Auktionen ──────────────────────────────────────────────────────────────
model ShopAuction {
  id               String    @id @default(cuid())
  itemId           String
  startPrice       Int
  minBidStep       Int       @default(50)
  currentBid       Int       @default(0)
  currentBidderId  String?
  endsAt           DateTime
  // active | ended | cancelled
  status           String    @default("active")
  winnerId         String?
  createdAt        DateTime  @default(now())

  item             ShopItem  @relation(fields: [itemId], references: [id])
  currentBidder    User?     @relation("currentAuctions", fields: [currentBidderId], references: [id])
  winner           User?     @relation("wonAuctions",     fields: [winnerId],         references: [id])
  bids             AuctionBid[]
}

model AuctionBid {
  id        String      @id @default(cuid())
  auctionId String
  userId    String
  amount    Int
  createdAt DateTime    @default(now())

  auction   ShopAuction @relation(fields: [auctionId], references: [id])
  user      User        @relation(fields: [userId], references: [id])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime
  @@unique([identifier, token])
}

model EventSeries {
  id          String   @id @default(cuid())
  name        String
  description String?
  createdAt   DateTime @default(now())
  events      Event[]
}

model Event {
  id             String   @id @default(cuid())
  title          String
  description    String?
  game           String?
  startAt        DateTime
  maxPlayers     Int?
  pointReward    Int      @default(50)
  type           String   @default("community")
  status         String   @default("open")
  discordEventId String?  @unique
  seriesId       String?
  createdAt      DateTime @default(now())

  series        EventSeries?        @relation(fields: [seriesId], references: [id])
  registrations EventRegistration[]
  tournament    Tournament?
}

model EventRegistration {
  id        String   @id @default(cuid())
  userId    String
  eventId   String
  joinedAt  DateTime @default(now())
  attended  Boolean  @default(false)
  user      User     @relation(fields: [userId], references: [id])
  event     Event    @relation(fields: [eventId], references: [id])
  @@unique([userId, eventId])
}

model Tournament {
  id           String   @id @default(cuid())
  eventId      String   @unique
  // single_elimination | double_elimination | round_robin | ffa | coop_stats
  format       String   @default("single_elimination")
  status       String   @default("pending")
  // JSON: {"1": 100, "2": 50, "3": 25} — Punkte pro Platzierung
  pointsConfig String?
  // JSON: ["Kills","Assists","Punkte"] — für ffa/coop_stats sichtbare Stat-Spalten
  statFields        String?
  // Bestätigte Endplatzierung: JSON ["userId1","userId2",...]
  finalRankingJson  String?
  // Optionale Begründung für Änderungen (z.B. Disqualifikation)
  finalRankingNote  String?
  createdAt    DateTime @default(now())
  event        Event    @relation(fields: [eventId], references: [id])

  participants TournamentParticipant[]
  matches      Match[]
  teams        Team[]
}

model TournamentParticipant {
  id           String     @id @default(cuid())
  tournamentId String
  userId       String
  seed         Int?
  eliminated   Boolean    @default(false)
  finalRank    Int?
  tournament   Tournament @relation(fields: [tournamentId], references: [id])
  user         User       @relation(fields: [userId], references: [id])
  @@unique([tournamentId, userId])
}

// Nur für team_vs_team-Formate
model Team {
  id           String       @id @default(cuid())
  tournamentId String
  name         String
  color        String?
  tournament   Tournament   @relation(fields: [tournamentId], references: [id])
  members      TeamMember[]
  matchEntries MatchEntry[]
}

model TeamMember {
  id     String @id @default(cuid())
  teamId String
  userId String
  team   Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id])
  @@unique([teamId, userId])
}

model Match {
  id           String       @id @default(cuid())
  tournamentId String
  round        Int
  position     Int
  title        String?
  scheduledAt  DateTime?
  notes        String?
  // 1v1 / single_elimination: player1Id/player2Id/score1/score2/winnerId
  player1Id    String?
  player2Id    String?
  winnerId     String?
  score1       Int?
  score2       Int?
  playedAt     DateTime?
  tournament   Tournament   @relation(fields: [tournamentId], references: [id])
  // ffa / coop_stats / team_vs_team: eine Zeile pro Teilnehmer
  entries      MatchEntry[]
}

// Flexible Teilnehmer-Zeile für FFA, Coop und Team-Matches
model MatchEntry {
  id        String  @id @default(cuid())
  matchId   String
  // Entweder userId (Einzelspieler) oder teamId (Team)
  userId    String?
  teamId    String?
  placement Int?    // Platzierung (1 = Erster)
  score     Int?    // Numerischer Score/Punkte im Match
  // JSON: {"Kills": 12, "Assists": 3} — passend zu Tournament.statFields
  statsJson String?
  match     Match   @relation(fields: [matchId], references: [id], onDelete: Cascade)
  user      User?   @relation(fields: [userId], references: [id])
  team      Team?   @relation(fields: [teamId], references: [id])
}

model Quest {
  id          String   @id @default(cuid())
  title       String
  description String
  // VOICE_MINUTES | MESSAGES | EVENT_ATTEND | TOURNAMENT
  type        String
  target      Int
  reward      Int
  month       Int
  year        Int
  createdAt   DateTime @default(now())

  progress    UserQuestProgress[]
}

model UserQuestProgress {
  id          String    @id @default(cuid())
  userId      String
  questId     String
  current     Int       @default(0)
  completed   Boolean   @default(false)
  completedAt DateTime?
  rewarded    Boolean   @default(false)

  user        User      @relation(fields: [userId], references: [id])
  quest       Quest     @relation(fields: [questId], references: [id], onDelete: Cascade)

  @@unique([userId, questId])
}

// ── Spendenpool ─────────────────────────────────────────────────────────────

model PoolExpense {
  id          String   @id @default(cuid())
  title       String   // z.B. "Minecraft Server Oktober"
  description String?  // optionale Details
  amount      Float    // in Euro
  date        DateTime // Datum der Ausgabe
  createdAt   DateTime @default(now())
}

model Donation {
  id        String   @id @default(cuid())
  userId    String
  amount    Float    // in Euro, nur für Admin sichtbar
  month     Int      // 1–12
  year      Int
  note      String?  // optionale Admin-Notiz
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id])
  // Kein Unique-Constraint → mehrere Einträge pro User pro Monat möglich
}

model PointTransaction {
  id        String   @id @default(cuid())
  userId    String
  amount    Int
  reason    String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}

// ── Level-Up-League ─────────────────────────────────────────────────────────

model LulSeason {
  id             String   @id @default(cuid())
  number         Int      // Saison-Nummer (1, 2, ...)
  name           String?  // optionaler Anzeigename
  period         String?  // "Mai 2026 - Dezember 2026"
  totalSpieltage Int      @default(8)
  // upcoming | active | finished | archived
  status         String   @default("upcoming")
  // true = Vergangene Saison, Daten nur als Endergebnis importiert
  isLegacy       Boolean  @default(false)
  createdAt      DateTime @default(now())

  spieltage     LulSpieltag[]
  legacyEntries LulLegacyEntry[]
}

// Aggregiertes Saison-Endergebnis für vergangene Saisons ohne Spieltag-Details
model LulLegacyEntry {
  id          String    @id @default(cuid())
  seasonId    String
  userId      String
  totalPts    Int       @default(0)
  asPlayer    Int       @default(0)  // Einsätze als Mitspieler
  asSpectator Int       @default(0)  // Einsätze als Zuschauer
  wins        Int       @default(0)  // Game Winner
  champs      Int       @default(0)  // Community-Champ
  trost       Int       @default(0)  // Trostpreis
  dominion    Int       @default(0)  // Dominion Bonus
  votes       Int       @default(0)  // Votes
  season      LulSeason @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id])
  @@unique([seasonId, userId])
}

model LulSpieltag {
  id           String    @id @default(cuid())
  seasonId     String
  number       Int       // 1-8
  game         String    // "Brawlhalla"
  gameType     String?   // "Beat-em Up"
  platform     String?   // "PC/Konsole"
  scheduledAt  DateTime?
  // upcoming | active | finished
  status       String    @default("upcoming")
  // JSON: {"1": 10, "2": 5, "3": 3} – Punkte pro Spielplatzierung
  pointsConfig String?
  season       LulSeason @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  entries      LulEntry[]
}

model LulEntry {
  id             String      @id @default(cuid())
  spieltagId     String
  userId         String
  // player | spectator
  role           String      @default("player")
  // JSON number[]: Punkte pro Runde (max 10), nur für Mitspieler
  roundScores    String?
  totalGameScore Int         @default(0)
  placement      Int?        // Spieltagsplatzierung (1 = Sieger)
  gameWinner     Boolean     @default(false) // Mitspieler-Sieg
  communityChamp Boolean     @default(false) // Zuschauer-Umfragesieg
  trostpreis     Boolean     @default(false) // Trostpreis-Umfrage
  voted          Boolean     @default(false) // hat an Umfrage teilgenommen
  dominionBonus  Boolean     @default(false) // 3 Siege in Folge
  lulPoints      Int         @default(0)     // LUL-Punkte gesamt für diesen Spieltag
  spieltag       LulSpieltag @relation(fields: [spieltagId], references: [id], onDelete: Cascade)
  user           User        @relation(fields: [userId], references: [id])
  @@unique([spieltagId, userId])
}
