# Discord Bot – Kanäle
# DISCORD_NEWS_CHANNEL_ID=      # News-Kanal: alle Bot-Nachrichten landen hier (Events, Turniere, Rangliste, Geburtstage, Rang-Aufstiege)
# DISCORD_LUL_CHANNEL_ID=       # Level-Up-League Spielvorschläge (eigener Kanal)
# DISCORD_EVENTS_PING=@here     # Ping bei Event-Start (Standard: @here)
#
# Pro Event kann in der Admin-Oberfläche eine abweichende Kanal-ID gesetzt werden.

# Push Notifications (Web Push VAPID)
# Generiere einmalig mit: node -e "const wp=require('web-push');console.log(JSON.stringify(wp.generateVAPIDKeys()))"
VAPID_PUBLIC_KEY=your_public_key_here
VAPID_PRIVATE_KEY=your_private_key_here
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your_public_key_here   # muss gleich wie VAPID_PUBLIC_KEY sein
